{
  "name": "forge-test-harness",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 30 chaos test harness for the Forge stack (control plane + agent + Docker).",
  "scripts": {
    "build": "tsc --noEmit",
    "test": "jest --runInBand",
    "harness": "RUN_HARNESS=true jest --runInBand",
    "stack:up": "docker compose -f docker-compose.test.yml up -d --build --wait",
    "stack:down": "docker compose -f docker-compose.test.yml down -v",
    "stack:logs": "docker compose -f docker-compose.test.yml logs -f"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  }
}
